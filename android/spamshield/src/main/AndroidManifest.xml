<?xml version="1.0" encoding="utf-8"?>
<!-- spamshield core library. INTERNET is needed only for the OPT-IN feed/crowd downloads
     (threat feeds, crowd feed GET, report POST); offline classification uses no network.
     WorkManager (androidx.work) self-registers its components via its own manifest merge. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
</manifest>
